
                <!-- Loading overlay -->
                <Grid Grid.Row="1" 
                      Background="#80FFFFFF"
                      Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Loading..." 
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <ProgressBar IsIndeterminate="True" 
                                     Width="24" 
                                     Height="24"
                                     Margin="0,10,0,0"/>
                    </StackPanel>
                </Grid>
                
                <!-- Empty state -->
                <TextBlock Grid.Row="1" 
                           Text="No sequences found. Click 'Create New' to add one."
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#757575"
                           FontSize="14"
                           Visibility="{Binding HasNoSequences, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
