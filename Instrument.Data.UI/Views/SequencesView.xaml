<UserControl x:Class="Instrument.Data.UI.Views.SequencesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Instrument.Data.UI.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- Title -->
            <TextBlock Grid.Column="0"
                       Text="{Binding Title}" 
                       FontSize="24"
                       FontWeight="Medium"
                       Margin="0,0,0,8"/>
            
            <!-- Actions -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Refresh" 
                        Command="{Binding LoadSequencesCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="0,0,10,0"/>
                
                <Button Content="Create New"
                        Command="{Binding CreateSequenceCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"/>
            </StackPanel>
        </Grid>
        
        <!-- Sequences List -->
        <materialDesign:Card Grid.Row="1" 
                             Padding="0"
                             materialDesign:ShadowAssist.ShadowDepth="Depth1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Column Headers -->
                <Grid Grid.Row="0" 
                      Background="{DynamicResource PrimaryHueMidBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" 
                               Text="Sequence Name"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Margin="16,10"/>
                    
                    <TextBlock Grid.Column="1" 
                               Text="Time"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Margin="0,10,60,10"/>
                    
                    <TextBlock Grid.Column="2" 
                               Text="Parallel"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Margin="0,10,60,10"/>
                </Grid>
                
                <!-- Sequences -->
                <ListView Grid.Row="1"
                          ItemsSource="{Binding Sequences}"
                          SelectedItem="{Binding SelectedSequence}"
                          BorderThickness="0"
                          Background="Transparent"
                          materialDesign:ShadowAssist.ShadowDepth="Depth0">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Name}"
                                           FontWeight="Medium"/>
                                
                                <TextBlock Grid.Column="1"
                                           Text="{Binding WorstCaseTime}"
                                           Width="110"
                                           TextAlignment="Right"/>
                                
                                <TextBlock Grid.Column="2"
                                           Text="{Binding CanBeParallel}"
                                           Width="70"
                                           TextAlignment="Center"/>
                                
                                <StackPanel Grid.Column="3" 
                                            Orientation="Horizontal" 
                                            Width="120">
                                    <Button Content="View" 
                                            Command="{Binding DataContext.ViewSequenceCommand, 
                                                      RelativeSource={RelativeSource AncestorType=ListView}}"
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            Width="50" 
                                            Margin="0,0,10,0"/>
                                    
                                    <Button Content="Delete" 
                                            Command="{Binding DataContext.DeleteSequenceCommand, 
                                                      RelativeSource={RelativeSource AncestorType=ListView}}"
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            Width="50"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                
                <!-- Loading overlay -->
                <Grid Grid.Row="1" 
                      Background="#80FFFFFF"
                      Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Loading..." 
                                   FontSize="16"
                                   FontWeight="Medium"
                                   HorizontalAlignment="Center"/>
                        <ProgressBar IsIndeterminate="True" 
                                     Width="24" 
                                     Height="24"
                                     Margin="0,10,0,0"/>
                    </StackPanel>
                </Grid>
                
                <!-- Empty state -->
                <TextBlock Grid.Row="1" 
                           Text="No sequences found. Click 'Create New' to add one."
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#757575"
                           FontSize="14"
                           Visibility="{Binding HasNoSequences, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
