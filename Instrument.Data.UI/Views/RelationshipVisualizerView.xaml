<UserControl x:Class="Instrument.Data.UI.Views.RelationshipVisualizerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Instrument.Data.UI.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- Title -->
            <TextBlock Grid.Column="0"
                       Text="{Binding Title}" 
                       Style="{DynamicResource MaterialDesignHeadline5TextBlock}"/>
        </Grid>
        
        <!-- Main Content -->
        <materialDesign:Card Grid.Row="1" Padding="16" materialDesign:ShadowAssist.ShadowDepth="Depth1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Entity Selection -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" 
                               Text="Select an entity to visualize: " 
                               VerticalAlignment="Center" 
                               Margin="0,0,16,0"/>
                    
                    <ComboBox Grid.Column="1" 
                              ItemsSource="{Binding EntityTypes}"
                              SelectedItem="{Binding SelectedEntityType, Mode=TwoWay}"
                              DisplayMemberPath="Name"
                              materialDesign:HintAssist.Hint="Select entity type"
                              Style="{StaticResource MaterialDesignFilledComboBox}"/>
                    
                    <Button Grid.Column="2" 
                            Content="Visualize"
                            Command="{Binding VisualizeCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Margin="16,0,0,0"/>
                </Grid>
                
                <!-- Visualization Canvas -->
                <Border Grid.Row="1" 
                        BorderBrush="{DynamicResource MaterialDesignDivider}" 
                        BorderThickness="1"
                        Background="{DynamicResource MaterialDesignCardBackground}">
                    <Grid>
                        <Canvas x:Name="VisualizationCanvas" 
                                IsEnabled="{Binding IsVisualizationReady}"
                                Visibility="{Binding IsVisualizationReady, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ItemsControl ItemsSource="{Binding EntityNodes}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}" />
                                        <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <materialDesign:Card Padding="16" 
                                                             Width="180" 
                                                             Height="100"
                                                             materialDesign:ShadowAssist.ShadowDepth="Depth1"
                                                             Background="{Binding Background}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" 
                                                           FontWeight="Bold"
                                                           TextWrapping="Wrap"
                                                           Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding Type}" 
                                                           TextWrapping="Wrap"
                                                           Opacity="0.7"
                                                           FontSize="12"/>
                                                <TextBlock Text="{Binding PropertiesCount, StringFormat='Properties: {0}'}" 
                                                           TextWrapping="Wrap"
                                                           Margin="0,8,0,0"
                                                           FontSize="12"/>
                                            </StackPanel>
                                        </materialDesign:Card>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            
                            <!-- Relationship lines -->
                            <ItemsControl ItemsSource="{Binding RelationshipLines}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Line X1="{Binding X1}" 
                                              Y1="{Binding Y1}" 
                                              X2="{Binding X2}" 
                                              Y2="{Binding Y2}" 
                                              Stroke="{DynamicResource PrimaryHueMidBrush}" 
                                              StrokeThickness="2" 
                                              StrokeDashArray="{Binding DashPattern}">
                                            <Line.ToolTip>
                                                <TextBlock Text="{Binding Relationship}"/>
                                            </Line.ToolTip>
                                        </Line>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            
                            <!-- Relationship labels -->
                            <ItemsControl ItemsSource="{Binding RelationshipLabels}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}" />
                                        <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Text}" 
                                                   Background="{DynamicResource MaterialDesignPaper}"
                                                   Padding="4,2"
                                                   FontSize="11"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Canvas>
                        
                        <!-- Empty state / Loading state -->
                        <StackPanel HorizontalAlignment="Center" 
                                    VerticalAlignment="Center"
                                    Visibility="{Binding IsVisualizationReady, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                            <TextBlock Text="Select an entity type and click Visualize to see the relationships" 
                                      TextAlignment="Center"
                                      FontSize="16"
                                      Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                            <materialDesign:PackIcon Kind="GraphOutline" 
                                                     Width="64" 
                                                     Height="64" 
                                                     HorizontalAlignment="Center"
                                                     Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                     Margin="0,24,0,0"/>
                        </StackPanel>
                        
                        <!-- Loading overlay -->
                        <Grid Background="#A0FFFFFF"
                              Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <materialDesign:Card Padding="24" materialDesign:ShadowAssist.ShadowDepth="Depth3">
                                    <StackPanel>
                                        <TextBlock Text="Generating Visualization..." 
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,16"
                                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"/>
                                        <ProgressBar IsIndeterminate="True" 
                                                     Width="200" 
                                                     Height="4"/>
                                    </StackPanel>
                                </materialDesign:Card>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
