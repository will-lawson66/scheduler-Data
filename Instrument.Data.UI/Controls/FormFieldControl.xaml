<UserControl x:Class="Instrument.Data.UI.Controls.FormFieldControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Instrument.Data.UI.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="70" d:DesignWidth="300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Label -->
        <TextBlock Grid.Row="0" 
                   x:Name="LabelTextBlock"
                   Text="{Binding Label, RelativeSource={RelativeSource AncestorType=local:FormFieldControl}}"
                   FontWeight="Medium"
                   Margin="0,0,0,4"/>
        
        <!-- Content -->
        <ContentPresenter Grid.Row="1" 
                          x:Name="ContentPresenter"
                          Content="{Binding Content, RelativeSource={RelativeSource AncestorType=local:FormFieldControl}}"/>
        
        <!-- Helper Text or Error -->
        <TextBlock Grid.Row="2" 
                   x:Name="HelperTextBlock"
                   Text="{Binding HelperText, RelativeSource={RelativeSource AncestorType=local:FormFieldControl}}"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="12"
                   Margin="0,4,0,0"
                   Visibility="{Binding HasHelperText, RelativeSource={RelativeSource AncestorType=local:FormFieldControl}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        
        <TextBlock Grid.Row="2" 
                   x:Name="ErrorTextBlock"
                   Text="{Binding ErrorText, RelativeSource={RelativeSource AncestorType=local:FormFieldControl}}"
                   Foreground="{StaticResource ErrorBrush}"
                   FontSize="12"
                   Margin="0,4,0,0"
                   Visibility="{Binding HasError, RelativeSource={RelativeSource AncestorType=local:FormFieldControl}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
    </Grid>
</UserControl>
