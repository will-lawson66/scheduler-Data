<UserControl x:Class="Instrument.Scheduling.UI.Views.SequenceDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Instrument.Scheduling.UI.Views"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- Back Button -->
            <Button Grid.Column="0"
                    Content="← Back"
                    Command="{Binding GoBackCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="0,0,20,0"/>
            
            <!-- Title -->
            <TextBlock Grid.Column="1"
                       Text="{Binding Title}" 
                       Style="{StaticResource HeaderTextStyle}"/>
            
            <!-- Delete Button (only shown when editing) -->
            <Button Grid.Column="2"
                    Content="Delete"
                    Command="{Binding DeleteAsyncCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Background="#FFEBEE"
                    BorderBrush="#E57373"
                    Foreground="#D32F2F"
                    Visibility="{Binding IsNew, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
        </Grid>
        
        <!-- Form Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Basic Information -->
                <Border Grid.Row="0" 
                        Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" 
                                Text="Basic Information"
                                Style="{StaticResource SubHeaderTextStyle}"
                                Margin="0,0,0,15"/>
                        
                        <!-- Name -->
                        <StackPanel Grid.Row="1" Margin="0,0,0,15">
                            <TextBlock Text="Name" FontWeight="Medium" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding SequenceName, UpdateSourceTrigger=PropertyChanged}"
                                    FontSize="14"
                                    Padding="8"
                                    Height="35"/>
                        </StackPanel>
                        
                        <!-- Description -->
                        <StackPanel Grid.Row="2" Margin="0,0,0,15">
                            <TextBlock Text="Description (Optional)" FontWeight="Medium" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding SequenceDescription, UpdateSourceTrigger=PropertyChanged}"
                                    FontSize="14"
                                    Padding="8"
                                    TextWrapping="Wrap"
                                    AcceptsReturn="True"
                                    Height="60"
                                    VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                        
                        <!-- Worst Case Time -->
                        <StackPanel Grid.Row="3" Margin="0,0,0,15">
                            <TextBlock Text="Worst Case Time (hh:mm:ss)" FontWeight="Medium" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding WorstCaseTime, UpdateSourceTrigger=PropertyChanged}"
                                    FontSize="14"
                                    Padding="8"
                                    Height="35"/>
                        </StackPanel>
                        
                        <!-- Can Be Parallel -->
                        <CheckBox Grid.Row="4"
                                Content="Can Be Executed in Parallel"
                                IsChecked="{Binding CanBeParallel}"
                                FontSize="14"/>
                    </Grid>
                </Border>
                
                <!-- Parameters -->
                <Border Grid.Row="1" 
                        Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" 
                                Text="Parameters"
                                Style="{StaticResource SubHeaderTextStyle}"
                                Margin="0,0,0,15"/>
                        
                        <!-- Parameters Grid -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Available Parameters -->
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Grid.Row="0" 
                                        Text="Available Parameters"
                                        FontWeight="Medium"
                                        Margin="0,0,0,10"/>
                                
                                <ListView Grid.Row="1"
                                        ItemsSource="{Binding AvailableParameters}"
                                        SelectedItem="{Binding SelectedAvailableParameter}"
                                        BorderThickness="1"
                                        BorderBrush="#DDDDDD"
                                        Height="300">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                            
                            <!-- Actions -->
                            <StackPanel Grid.Column="1" 
                                        VerticalAlignment="Center"
                                        Margin="10,0">
                                <Button Content="→"
                                        Command="{Binding AddParameterAsyncCommand}"
                                        Margin="0,0,0,10"
                                        Width="40"
                                        Height="40"
                                        IsEnabled="{Binding SelectedAvailableParameter, Converter={StaticResource NullValueToBooleanConverter}}"/>
                                
                                <Button Content="←"
                                        Command="{Binding RemoveParameterAsyncCommand}"
                                        Width="40"
                                        Height="40"
                                        IsEnabled="{Binding SelectedSequenceParameter, Converter={StaticResource NullValueToBooleanConverter}}"/>
                            </StackPanel>
                            
                            <!-- Sequence Parameters -->
                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Grid.Row="0" 
                                        Text="Sequence Parameters"
                                        FontWeight="Medium"
                                        Margin="0,0,0,10"/>
                                
                                <ListView Grid.Row="1"
                                        ItemsSource="{Binding SequenceParameters}"
                                        SelectedItem="{Binding SelectedSequenceParameter}"
                                        BorderThickness="1"
                                        BorderBrush="#DDDDDD"
                                        Height="300">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
        
        <!-- Footer -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <Button Grid.Column="1"
                    Content="Cancel"
                    Command="{Binding GoBackCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="100"
                    Margin="0,0,10,0"/>
            
            <Button Grid.Column="2"
                    Content="Save"
                    Command="{Binding SaveAsyncCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="100"/>
        </Grid>
        
        <!-- Loading overlay -->
        <Grid Grid.Row="0" Grid.RowSpan="3" 
              Background="#80FFFFFF"
              Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Loading..." 
                           FontSize="16"
                           HorizontalAlignment="Center"/>
                <ProgressBar IsIndeterminate="True" 
                             Width="200" 
                             Height="5"
                             Margin="0,10,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
