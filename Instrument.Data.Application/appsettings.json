{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "DataStorage": {
    "Provider": "Sqlite",
    "ConnectionString": "Data Source=./data/scheduler.db",
    "JsonFilePath": "./data/sequence_definitions.json"
  },
  "StorageConfiguration": {
    "Provider": "SQLite",
    "ConnectionString": "Data Source=./data/scheduler.db"
  },
  "GrpcGatewayOptions": {
    "DefaultTimeoutSeconds": 20,
    "MaxConcurrentRequests": 5,
    "RetryOptions": {
      "MaxAttempts": 5,
      "BaseDelayMs": 1000,
      "BackoffMultiplier": 2
    }
  }
}